---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import ProjectCard from '../../components/ProjectCard.astro'
import ExperienceList from '../../components/ExperienceList.astro'

const projects = [
  {
    title: 'Burger King 豪點王 Redesign',
    client: 'Burger King',
    metric: 'Checkout reduced from 3 taps to instant',
    href: '/en/projects/burger-king',
    video: '/videos/burger-king-hero.webm',
  },
  {
    title: 'Symptomtrace App & Dashboard',
    client: 'Symptomtrace',
    metric: 'Cross-border 3-country collab, dual platform',
    href: '/en/projects/squirrel-doctor',
    video: '/videos/squirrel-doctor-hero.webm',
  },
  {
    title: 'WINGSTARS Cheerleading Website',
    client: 'WINGSTARS',
    metric: 'Fan ecosystem built from ground up',
    href: '/en/projects/wingstar',
    image: '/images/wingstar-cover.png',
  },
  {
    title: 'TSG Membership System',
    client: 'TSG Group',
    metric: 'Cross-brand unification + new Design System',
    href: '/en/projects/tsg-membership',
    image: '/images/taigun-cover.png',
  },
]
---

<BaseLayout lang="en" title="Esme Chang — Product Designer">
  <Hero lang="en" />

  <div class="relative lg:w-[70%] lg:pl-[10vw] lg:pr-8" style="z-index: 1;">
    <section id="projects" class="pt-16 pb-24">
      <div class="px-8 lg:px-0">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    </section>

    <ExperienceList lang="en" />
  </div>
</BaseLayout>
