---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero from '../../components/Hero.astro'
import ProjectCard from '../../components/ProjectCard.astro'
import ExperienceList from '../../components/ExperienceList.astro'

const projects = [
  {
    title: 'Burger King 豪點王 Redesign',
    description: 'Redesigned the Burger King LINE LIFF interface, restructuring information hierarchy and optimizing coupon categorization and navigation.',
    href: '/en/projects/burger-king',
    video: '/videos/burger-king-hero.webm',
  },
  {
    title: 'Symptomtrace App & Dashboard',
    description: 'A healthcare management product serving elderly patients, families, and medical staff — dual-platform design covering a patient-facing app and a clinical dashboard.',
    href: '/en/projects/squirrel-doctor',
    video: '/videos/squirrel-doctor-hero.webm',
  },
  {
    title: 'WINGSTARS Cheerleading Official Website',
    description: 'Built an interactive platform for a cheerleading fan community, featuring personal pages, leaderboards, collection showcases, and a merchandise store.',
    href: '/en/projects/wingstar',
    image: '/images/wingstar-cover.png',
  },
  {
    title: 'TSG Membership System',
    description: 'Redesigned the membership system to optimize registration flow, points & rewards, and coupon management, while establishing a consistent Design System.',
    href: '/en/projects/tsg-membership',
    image: '/images/taigun-cover.png',
  },
]
---

<BaseLayout lang="en" title="Esme Chang — Product Designer">
  <Hero lang="en" />

  <section id="projects" class="pb-20">
    <div class="max-w-[1200px] mx-auto px-8">
      <h2 class="text-2xl font-bold mb-2">Projects</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        {projects.map((project) => (
          <ProjectCard {...project} lang="en" />
        ))}
      </div>
    </div>
  </section>

  <ExperienceList lang="en" />
</BaseLayout>
