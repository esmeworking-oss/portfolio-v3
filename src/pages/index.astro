---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ProjectCard from '../components/ProjectCard.astro'
import ExperienceList from '../components/ExperienceList.astro'

const projects = [
  {
    title: '豪點王 Redesign',
    description: '漢堡王 LINE LIFF 介面改版，重整資訊層級、優化票券分類與導航體驗。',
    href: '/projects/burger-king',
    video: '/videos/burger-king-hero.webm',
  },
  {
    title: '松鼠醫生 App 與後台',
    description: '醫療健康管理產品，服務高齡患者、家屬與醫護人員，涵蓋患者端 App 與臨床端後台的雙端設計。',
    href: '/projects/squirrel-doctor',
    video: '/videos/squirrel-doctor-hero.webm',
  },
  {
    title: 'WINGSTARS 啦啦隊官方網站',
    description: '為啦啦隊粉絲社群打造互動平台，涵蓋個人頁面、排行榜、收藏展示櫃與商城等功能。',
    href: '/projects/wingstar',
    image: '/images/wingstar-cover.png',
  },
  {
    title: '台鋼會員系統',
    description: '重新設計會員系統，優化註冊流程、點數經濟與票券管理，建立一致的 Design System。',
    href: '/projects/tsg-membership',
    image: '/images/taigun-cover.png',
  },
]
---

<BaseLayout lang="zh">
  <Hero lang="zh" />

  <section id="projects" class="pb-20">
    <div class="max-w-[1200px] mx-auto px-8">
      <h2 class="text-2xl font-bold mb-2">Projects</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        {projects.map((project) => (
          <ProjectCard {...project} lang="zh" />
        ))}
      </div>
    </div>
  </section>

  <ExperienceList lang="zh" />
</BaseLayout>
