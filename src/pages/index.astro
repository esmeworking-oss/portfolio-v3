---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.astro'
import ProjectCard from '../components/ProjectCard.astro'
import ExperienceList from '../components/ExperienceList.astro'

const projects = [
  {
    title: 'AI 協作體系實戰',
    client: '個人專案',
    metric: '一個人完成產品全週期，建站時間從 14 天壓縮至 5 天',
    href: '/projects/ai-workflow',
    image: '/images/ai-workflow-cover.png',
  },
  {
    title: '豪點王 Redesign',
    client: '漢堡王',
    metric: '結帳條碼動線從 3 步縮短至 0 步',
    href: '/projects/burger-king',
    video: '/videos/burger-king-hero.webm',
  },
  {
    title: '松鼠醫生 App 與後台',
    client: '星坦科技',
    metric: '跨境三國協作，雙端設計全流程',
    href: '/projects/squirrel-doctor',
    video: '/videos/squirrel-doctor-hero.webm',
  },
  {
    title: 'WINGSTARS 啦啦隊官方網站',
    client: 'WINGSTARS',
    metric: '粉絲生態系從零規劃到上線',
    href: '/projects/wingstar',
    image: '/images/wingstar-cover.png',
  },
  {
    title: '台鋼會員系統',
    client: '台鋼集團',
    metric: '跨品牌整合會員系統 + 建立全新 Design System',
    href: '/projects/tsg-membership',
    image: '/images/taigun-cover.png',
  },
]
---

<BaseLayout lang="zh">
  <Hero lang="zh" />

  <div class="relative lg:w-[70%] lg:pl-[10vw] lg:pr-8" style="z-index: 1;">
    <section id="projects" class="pt-16 pb-24">
      <div class="px-8 lg:px-0">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
          {projects.map((project) => (
            <ProjectCard {...project} />
          ))}
        </div>
      </div>
    </section>

    <ExperienceList lang="zh" />
  </div>
</BaseLayout>
