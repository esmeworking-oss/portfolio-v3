---
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

type Lang = 'zh' | 'en'
interface Props {
  title?: string
  lang?: Lang
}

const { title = 'Esme Chang — Product Designer', lang = 'zh' } = Astro.props
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={lang === 'zh' ? 'Esme Chang — 產品設計師作品集' : 'Esme Chang — Product Designer Portfolio'} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={lang === 'zh' ? 'Esme Chang — 產品設計師作品集' : 'Esme Chang — Product Designer Portfolio'} />
    <meta property="og:image" content="/icon.png" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&family=Noto+Sans+TC:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="text-black font-sans antialiased bg-white min-h-screen relative">
    <Navbar lang={lang} />
    <main class="relative z-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
