---
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import { useTranslations } from '../i18n/utils'

type Lang = 'zh' | 'en'
interface Props {
  title: string
  headline: string
  skills: string[]
  roles: string[]
  lang?: Lang
  titleEn?: string
  headlineEn?: string
  skillsEn?: string[]
  rolesEn?: string[]
}

const { title, headline, skills, roles, lang = 'zh' } = Astro.props
const t = useTranslations(lang)

const projects = [
  { slug: 'ai-workflow', title: '從設計到上線：AI 協作體系', titleEn: 'Design-Led AI Orchestration' },
  { slug: 'squirrel-doctor', title: '松鼠醫生 App 與後台', titleEn: 'Symptomtrace App & Dashboard' },
  { slug: 'burger-king', title: '豪點王 Redesign', titleEn: 'Burger King 豪點王 Redesign' },
  { slug: 'wingstar', title: 'WINGSTARS 啦啦隊官方網站', titleEn: 'WINGSTARS Cheerleading Official Website' },
  { slug: 'tsg-membership', title: '台鋼會員系統', titleEn: 'TSG Membership System' },
]

const currentSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop()
const currentIndex = projects.findIndex((p) => p.slug === currentSlug)
const nextProject = projects[(currentIndex + 1) % projects.length]

const projectBase = lang === 'en' ? '/en/projects' : '/projects'
const nextTitle = lang === 'en' ? nextProject.titleEn : nextProject.title
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} — Esme Chang</title>
  </head>
  <body class="bg-white text-black font-sans antialiased grain-overlay">
    <Navbar lang={lang} />
    <article class="pt-32 pb-20">
      <div class="max-w-[1200px] mx-auto px-8">
        <a href={lang === 'en' ? '/en/' : '/'} class="inline-flex items-center text-sm text-black hover:opacity-60 transition-opacity mb-10">
          {t('layout.back')}
        </a>

        <div class="flex flex-col md:flex-row gap-12 md:gap-16">
          <!-- Left sidebar -->
          <aside class="md:w-[200px] shrink-0 space-y-8">
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2">{t('layout.skills')}</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {skills.map((skill) => (
                  <li>{skill}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2">{t('layout.roles')}</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {roles.map((role) => (
                  <li>{role}</li>
                ))}
              </ul>
            </div>
          </aside>

          <!-- Right content -->
          <div class="flex-1 min-w-0 project-body">
            <h1 class="text-3xl md:text-4xl font-bold leading-snug tracking-tight mb-3">{title}</h1>
            <p class="text-lg text-black leading-relaxed mb-[100px]">{headline}</p>
            <slot />

            <!-- Next project navigation -->
            <a
              href={`${projectBase}/${nextProject.slug}`}
              class="next-project-link group flex items-center justify-between mt-20 pt-8 border-t border-black/10 text-black hover:opacity-70 transition-opacity"
            >
              <div>
                <span class="text-xs font-semibold tracking-widest uppercase text-black/50">{t('layout.next')}</span>
                <p class="text-xl md:text-2xl font-bold mt-1">{nextTitle}</p>
              </div>
              <span class="text-2xl transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </article>
    <Footer />
  </body>
</html>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .project-body :global(section) {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    margin-bottom: 5rem;
  }

  .project-body :global(section:last-child) { margin-bottom: 0; }
  .project-body :global(section:nth-child(1)) { animation-delay: 0.1s; }
  .project-body :global(section:nth-child(2)) { animation-delay: 0.2s; }
  .project-body :global(section:nth-child(3)) { animation-delay: 0.3s; }
  .project-body :global(section:nth-child(4)) { animation-delay: 0.4s; }
  .project-body :global(section:nth-child(5)) { animation-delay: 0.5s; }
  .project-body :global(section:nth-child(6)) { animation-delay: 0.6s; }
  .project-body :global(section:nth-child(7)) { animation-delay: 0.7s; }
</style>
