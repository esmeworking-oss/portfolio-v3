---
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  headline: string
  skills: string[]
  roles: string[]
  titleEn?: string
  headlineEn?: string
  skillsEn?: string[]
  rolesEn?: string[]
}

const projects = [
  { slug: 'squirrel-doctor', title: '松鼠醫生 App 與後台', titleEn: 'Symptomtrace App & Dashboard' },
  { slug: 'burger-king', title: '豪點王 Redesign', titleEn: 'Burger King 豪點王 Redesign' },
  { slug: 'wingstar', title: 'WINGSTARS 啦啦隊官方網站', titleEn: 'WINGSTARS Cheerleading Official Website' },
  { slug: 'tsg-membership', title: '台鋼會員系統', titleEn: 'TSG Membership System' },
]

const currentSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop()
const currentIndex = projects.findIndex((p) => p.slug === currentSlug)
const nextProject = projects[(currentIndex + 1) % projects.length]

const { title, headline, skills, roles, titleEn, headlineEn, skillsEn, rolesEn } = Astro.props
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} — Esme Chang</title>
  </head>
  <body class="bg-[#FDF8EC] text-black font-sans antialiased grain-overlay">
    <Navbar />
    <article class="pt-32 pb-20">
      <div class="max-w-[1200px] mx-auto px-8">
        <a href="/" class="inline-flex items-center text-sm text-black hover:opacity-60 transition-opacity mb-10"
           data-i18n="layout.back">
          &larr; 返回首頁
        </a>

        <div class="flex flex-col md:flex-row gap-12 md:gap-16">
          <!-- Left sidebar -->
          <aside class="md:w-[200px] shrink-0 space-y-8">
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2" data-i18n="layout.skills">技能</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {skills.map((skill, i) => (
                  <li
                    data-zh={skillsEn ? skill : undefined}
                    data-en={skillsEn ? skillsEn[i] : undefined}
                  >{skill}</li>
                ))}
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2" data-i18n="layout.roles">我的角色</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {roles.map((role, i) => (
                  <li
                    data-zh={rolesEn ? role : undefined}
                    data-en={rolesEn ? rolesEn[i] : undefined}
                  >{role}</li>
                ))}
              </ul>
            </div>
          </aside>

          <!-- Right content -->
          <div class="flex-1 min-w-0 project-body">
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-3"
                data-zh={titleEn ? title : undefined}
                data-en={titleEn ?? undefined}>{title}</h1>
            <p class="text-lg text-black leading-relaxed mb-[100px]"
               data-zh={headlineEn ? headline : undefined}
               data-en={headlineEn ?? undefined}>{headline}</p>
            <slot />

            <!-- Next project navigation -->
            <a
              href={`/projects/${nextProject.slug}`}
              class="next-project-link group flex items-center justify-between mt-20 pt-8 border-t border-black/10 text-black hover:opacity-70 transition-opacity"
            >
              <div>
                <span class="text-xs font-semibold tracking-widest uppercase text-black/50" data-i18n="layout.next">下一個專案</span>
                <p class="text-xl md:text-2xl font-bold mt-1"
                   data-zh={nextProject.title}
                   data-en={nextProject.titleEn}>{nextProject.title}</p>
              </div>
              <span class="text-2xl transition-transform group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </article>
    <Footer />
  </body>
</html>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .project-body :global(section) {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    margin-bottom: 5rem;
  }

  .project-body :global(section:last-child) { margin-bottom: 0; }
  .project-body :global(section:nth-child(1)) { animation-delay: 0.1s; }
  .project-body :global(section:nth-child(2)) { animation-delay: 0.2s; }
  .project-body :global(section:nth-child(3)) { animation-delay: 0.3s; }
  .project-body :global(section:nth-child(4)) { animation-delay: 0.4s; }
  .project-body :global(section:nth-child(5)) { animation-delay: 0.5s; }
  .project-body :global(section:nth-child(6)) { animation-delay: 0.6s; }
  .project-body :global(section:nth-child(7)) { animation-delay: 0.7s; }
</style>
