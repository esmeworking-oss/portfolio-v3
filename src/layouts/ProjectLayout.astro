---
import '../styles/global.css'
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  headline: string
  skills: string[]
  roles: string[]
}

const { title, headline, skills, roles } = Astro.props
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} — Esme Chang</title>
  </head>
  <body class="bg-white text-black font-sans antialiased">
    <Navbar />
    <article class="pt-32 pb-20">
      <div class="max-w-[1200px] mx-auto px-8">
        <a href="/" class="inline-flex items-center text-sm text-black hover:opacity-60 transition-opacity mb-10">
          &larr; 返回首頁
        </a>

        <div class="flex flex-col md:flex-row gap-12 md:gap-16">
          <!-- Left sidebar -->
          <aside class="md:w-[200px] shrink-0 space-y-8">
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2">技能</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {skills.map((skill) => <li>{skill}</li>)}
              </ul>
            </div>
            <div>
              <h3 class="text-xs font-semibold tracking-widest uppercase mb-2">我的角色</h3>
              <ul class="text-sm text-black leading-relaxed space-y-1">
                {roles.map((role) => <li>{role}</li>)}
              </ul>
            </div>
          </aside>

          <!-- Right content -->
          <div class="flex-1 min-w-0 project-body">
            <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-3">{title}</h1>
            <p class="text-lg text-black leading-relaxed mb-[100px]">{headline}</p>
            <slot />
          </div>
        </div>
      </div>
    </article>
    <Footer />
  </body>
</html>

<style>
  /* 淡入動畫 */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .project-body :global(section) {
    opacity: 0;
    animation: fadeInUp 0.6s ease-out forwards;
    margin-bottom: 5rem;
  }

  .project-body :global(section:last-child) {
    margin-bottom: 0;
  }

  .project-body :global(section:nth-child(1)) { animation-delay: 0.1s; }
  .project-body :global(section:nth-child(2)) { animation-delay: 0.2s; }
  .project-body :global(section:nth-child(3)) { animation-delay: 0.3s; }
  .project-body :global(section:nth-child(4)) { animation-delay: 0.4s; }
  .project-body :global(section:nth-child(5)) { animation-delay: 0.5s; }
  .project-body :global(section:nth-child(6)) { animation-delay: 0.6s; }
  .project-body :global(section:nth-child(7)) { animation-delay: 0.7s; }
</style>
