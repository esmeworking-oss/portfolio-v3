---
interface Props {
  role: 'user' | 'ai'
  content: string
  label?: string
}
const { role, content, label } = Astro.props
---

<div class={`flex items-end gap-2 mb-3 ${role === 'user' ? 'justify-end' : 'justify-start'}`}>
  {role === 'ai' && (
    <div class="w-6 h-6 rounded-full bg-black flex items-center justify-center shrink-0 mb-0.5">
      <span class="text-white text-[8px] font-bold tracking-tight">AI</span>
    </div>
  )}
  <div class="flex flex-col gap-1 max-w-[82%]">
    {label && (
      <span class={`text-[10px] font-medium tracking-widest uppercase text-black/30 ${role === 'user' ? 'text-right' : 'text-left'}`}>
        {label}
      </span>
    )}
    <div class={`px-4 py-3 text-sm leading-relaxed ${
      role === 'user'
        ? 'bg-black text-white rounded-2xl rounded-br-sm'
        : 'bg-gray-100 text-black rounded-2xl rounded-bl-sm'
    }`}>
      {content}
    </div>
  </div>
  {role === 'user' && (
    <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center shrink-0 mb-0.5">
      <span class="text-black text-[8px] font-bold">E</span>
    </div>
  )}
</div>
