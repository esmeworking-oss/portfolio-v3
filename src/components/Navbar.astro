---
type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props

const pathname = Astro.url.pathname
const enUrl = pathname.startsWith('/en')
  ? pathname
  : pathname === '/'
    ? '/en/'
    : `/en${pathname}`
const zhUrl = pathname.startsWith('/en')
  ? pathname.replace(/^\/en/, '') || '/'
  : pathname
---

<nav class="nav-double-border fixed top-0 left-0 right-0 z-50 bg-[#FDF8EC]/80 backdrop-blur-sm">
  <div class="max-w-[1200px] mx-auto px-8 py-5 flex items-center justify-between">
    <a href={lang === 'en' ? '/en/' : '/'} class="hover:opacity-70 transition-opacity">
      <img src="/logo.svg" alt="Esme's Studio" class="h-[10px]" />
    </a>
    <div class="flex items-center gap-8 text-base">
      <a href={lang === 'en' ? '/en/#projects' : '/#projects'} class="text-black hover:opacity-60 transition-opacity">Work</a>
      <a href={lang === 'en' ? '/en/#experience' : '/#experience'} class="text-black hover:opacity-60 transition-opacity">Experience</a>
      <a href="mailto:esme.working@gmail.com" class="text-black hover:opacity-60 transition-opacity">Contact</a>
      <div class="lang-switch">
        <a href={zhUrl} class:list={['lang-btn', { active: lang === 'zh' }]}>ZH</a>
        <a href={enUrl} class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-double-border {
    border-bottom: 2px solid black;
    position: relative;
  }
  .nav-double-border::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: black;
  }
  .lang-switch {
    display: flex;
    border: 1px solid rgba(0, 0, 0, 0.22);
    border-radius: 999px;
    padding: 2px;
    gap: 1px;
  }
  .lang-btn {
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 3px 11px;
    border-radius: 999px;
    border: none;
    background: transparent;
    color: rgba(0, 0, 0, 0.4);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s, color 0.2s;
    line-height: 1.4;
    text-decoration: none;
  }
  .lang-btn:hover:not(.active) {
    color: rgba(0, 0, 0, 0.7);
  }
  .lang-btn.active {
    background: black;
    color: white;
  }
</style>
