---
type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props

const pathname = Astro.url.pathname
const enUrl = pathname.startsWith('/en')
  ? pathname
  : pathname === '/'
    ? '/en/'
    : `/en${pathname}`
const zhUrl = pathname.startsWith('/en')
  ? pathname.replace(/^\/en/, '') || '/'
  : pathname
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-black/[0.06]">
  <div class="px-8 lg:pl-[10vw] lg:pr-8 py-6 flex items-center justify-between">
    <a href={lang === 'en' ? '/en/' : '/'} class="text-sm font-medium tracking-widest uppercase hover:opacity-50 transition-opacity">
      Esme Chang
    </a>
    <div class="lang-switch">
      <a href={zhUrl} class:list={['lang-btn', { active: lang === 'zh' }]}>ZH</a>
      <a href={enUrl} class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
    </div>
  </div>
</nav>

<style>
  .lang-switch {
    display: flex;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: 999px;
    padding: 2px;
    gap: 1px;
  }
  .lang-btn {
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 3px 11px;
    border-radius: 999px;
    background: transparent;
    color: rgba(0, 0, 0, 0.35);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    text-decoration: none;
  }
  .lang-btn:hover:not(.active) {
    color: rgba(0, 0, 0, 0.6);
  }
  .lang-btn.active {
    background: black;
    color: white;
  }
</style>
