---
interface Props {
  title: string
  client: string
  metric: string
  href: string
  video?: string
  image?: string
}

const { title, client, metric, href, video, image } = Astro.props
---

<a href={href} class="group block">
  {video && (
    <div class="overflow-hidden bg-gray-100 rounded-xl">
      <video
        src={video}
        autoplay
        loop
        muted
        playsinline
        class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
      />
    </div>
  )}
  {!video && image && (
    <div class="overflow-hidden bg-gray-100 rounded-xl">
      <img
        src={image}
        alt={title}
        class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.02]"
      />
    </div>
  )}
  <div class="mt-5">
    <p class="text-xs text-black/40 tracking-widest uppercase mb-2">{client}</p>
    <h3 class="text-base font-medium leading-snug mb-1">
      {title}
      <span class="inline-block align-middle text-sm ml-1 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
    </h3>
    <p class="text-sm text-black/50">{metric}</p>
  </div>
</a>
