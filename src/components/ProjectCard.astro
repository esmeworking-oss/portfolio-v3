---
import { useTranslations } from '../i18n/utils'

type Lang = 'zh' | 'en'
interface Props {
  title: string
  description: string
  href: string
  video?: string
  image?: string
  i18nPrefix?: string
  lang?: Lang
}

const { title, description, href, video, image, i18nPrefix, lang = 'zh' } = Astro.props
const t = useTranslations(lang)
const displayTitle = i18nPrefix ? t(`${i18nPrefix}.title`) : title
const displayDesc = i18nPrefix ? t(`${i18nPrefix}.desc`) : description
---

<a href={href} class="group block">
  {video && (
    <div class="overflow-hidden h-[360px] transition-transform duration-300 group-hover:scale-[1.02]">
      <video
        src={video}
        autoplay
        loop
        muted
        playsinline
        class="w-full h-full object-cover"
      />
    </div>
  )}
  {!video && image && (
    <div class="overflow-hidden h-[360px] transition-transform duration-300 group-hover:scale-[1.02]">
      <img
        src={image}
        alt={displayTitle}
        class="w-full h-full object-cover"
      />
    </div>
  )}
  <h3 class="text-xl font-medium mt-5">
    <span>{displayTitle}</span>
    <span class="inline-block align-middle text-lg transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
  </h3>
  <p class="text-sm text-black mt-1">{displayDesc}</p>
</a>
