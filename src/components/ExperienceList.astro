---
import { useTranslations } from '../i18n/utils'

type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props
const t = useTranslations(lang)

const experiences = [
  { year: '2025 – 2026', i18nKey: 'exp.startech' },
  { year: '2025', i18nKey: 'exp.jianxun' },
  { year: '2023 – 2025', i18nKey: 'exp.himalaya' },
  { year: '2022', i18nKey: 'exp.pansying' },
]
---

<section id="experience" class="py-20">
  <div class="px-8 lg:px-0">
    <h2 class="text-2xl font-bold mb-10">Experience</h2>
    <div class="space-y-0">
      {experiences.map((exp) => (
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-0 py-4 border-t border-black">
          <span class="text-sm text-black sm:w-40 flex-shrink-0">{exp.year}</span>
          <span class="text-sm text-black sm:w-48 flex-shrink-0">{t(`${exp.i18nKey}.company`)}</span>
          <span class="text-sm text-black">{t(`${exp.i18nKey}.role`)}</span>
        </div>
      ))}
    </div>
  </div>
</section>
