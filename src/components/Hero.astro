---
type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props

const greeting = lang === 'zh' ? '嗨，我是 Esme。' : "Hi, I'm Esme."
const tagline = lang === 'zh'
  ? '專注於打造好用、好看的產品體驗的 Product Designer。'
  : 'Product designer focused on bridging business and users.'
const intro = lang === 'zh'
  ? ['嗨！我是 Esme，擅長從複雜的需求裡挖出真正的痛點，再用設計思維將它轉化為好用、好看的產品體驗。最近也著迷於把 AI 融入工作流程，從發想到落地等環節，每個都想試試看能不能更快、更有趣。', '對我來說，設計最迷人的地方，就是永遠有新的可能等著被探索。']
  : null
---

<section class="min-h-[85vh] flex flex-col justify-center pt-24 pb-8">
  <div class="px-8 lg:px-0 w-full">
    <div class="lg:max-w-[50%]">
      <h1 class="hero-animate text-[21px] md:text-[32px] font-semibold leading-[1.15] tracking-tight mb-6 text-primary">
        {greeting}
      </h1>
      {intro ? (
        <div class="hero-animate text-[14px] text-black/60 leading-relaxed space-y-4">
          {intro.map(p => <p>{p}</p>)}
        </div>
      ) : (
        <p class="hero-animate text-[14px] text-black/60 leading-relaxed">
          {tagline}
        </p>
      )}
    </div>
    <a
      href="#projects"
      class="hero-animate inline-block mt-16 text-sm text-black/40 hover:text-black transition-colors scroll-arrow"
      aria-label="scroll to projects"
    >
      ↓
    </a>
  </div>
</section>

<style>
  .scroll-arrow {
    font-size: 24px;
    animation: bob 2s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
</style>
