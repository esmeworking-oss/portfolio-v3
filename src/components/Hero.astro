---
type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props

const greeting = lang === 'zh' ? '嗨，我是 Esme。' : "Hi, I'm Esme."
const taglines = lang === 'zh'
  ? [
      '嗨！我是 Esme，擅長從複雜的需求裡挖出真正的痛點，再用設計思維將它轉化為好用、好看的產品體驗。最近也著迷於把 AI 融入工作流程，從發想到落地等環節，每個都想試試看能不能更快、更有趣。'
    ]
  : ['Product designer focused on bridging business and users.']
const cta = lang === 'zh' ? '看看我的作品' : 'View my work'
---

<section class="relative w-full overflow-hidden h-[60vh] mt-[68px]">
  <img
    src="/images/hero-bg.png"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 flex flex-col justify-center px-8 lg:pl-[10vw] lg:pr-8">
    <div>
      <h1 class="hero-animate text-[22px] md:text-[30px] lg:text-[36px] font-semibold leading-[1.1] tracking-tight text-black mb-4">
        {greeting}
      </h1>
      {taglines.map((line, i) => (
        <p class={`hero-animate text-[13px] md:text-[14px] text-black leading-relaxed max-w-[460px]${i > 0 ? ' mt-3' : ''}`}>
          {line}
        </p>
      ))}
      <a
        href="#projects"
        class="hero-animate inline-flex items-center gap-2 mt-8 px-6 py-[10px] rounded-full bg-black text-white text-sm font-medium hover:bg-black/80 transition-colors"
      >
        {cta} →
      </a>
    </div>
  </div>
</section>
