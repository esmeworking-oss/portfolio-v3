---
type Lang = 'zh' | 'en'
interface Props { lang?: Lang }
const { lang = 'zh' } = Astro.props

const greeting = lang === 'zh' ? '嗨，我是 Esme。' : "Hi, I'm Esme."
const taglines = lang === 'zh'
  ? [
      '我是一名 UI/UX 設計師與產品開發者，能從雜亂的原始需求中提煉<strong>核心痛點</strong>，將<strong>複雜邏輯轉化</strong>為直覺、高效的數位體驗。',
      '目前，我也深耕於 <strong>AI 驅動的設計工作流</strong>，致力於讓產品從發想到落地的過程變得更聰明、更精準。'
    ]
  : ['Product designer focused on bridging business and users.']
const cta = lang === 'zh' ? '看看我的作品' : 'View my work'
---

<section class="relative w-full overflow-hidden h-[60vh] mt-[68px]">
  <img
    src="/images/hero-bg.png"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 flex flex-col justify-center px-8 lg:pl-[10vw] lg:pr-8">
    <div>
      <h1 class="hero-animate text-[20px] md:text-[26px] lg:text-[30px] font-semibold leading-[1.1] tracking-tight text-black mb-4">
        {greeting}
      </h1>
      {taglines.map((line) => (
        <p class="hero-animate text-[13px] md:text-[14px] text-black leading-relaxed" set:html={line} />
      ))}
      <a
        href="#projects"
        class="hero-animate inline-flex items-center gap-2 mt-8 px-6 py-[10px] rounded-full bg-black text-white text-sm font-medium hover:bg-black/80 transition-colors"
      >
        {cta} →
      </a>
    </div>
  </div>
</section>
